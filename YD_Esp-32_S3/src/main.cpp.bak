#include <Arduino.h>
#include <WiFi.h>
#include <WebServer.h>

// Ağ ayarları
const char *ssid = "ESP32_Sensor_Node";
const char *password = "12345678";

WebServer server(80);

void handleRoot()
{
  String htmlSayfasi = R"rawliteral(
  <!DOCTYPE html>
<html lang="tr">
)rawliteral";
  server.send(200, "text/html", htmlSayfasi);
}

void setup()
{
  Serial.begin(115200);
  neopixelWrite(RGB_BUILTIN, 0, 0, 0);
  delay(1000);

  Serial.println("\nWiFi Statrting");

  WiFi.softAP(ssid, password);

  // 192.168.4.1
  IPAddress IP = WiFi.softAPIP();
  Serial.print("IP Address: ");
  Serial.println(IP);

  server.on("/", handleRoot);

  server.begin();
  Serial.println("HTTP post request started");
}

void loop()
{
  server.handleClient();
}
